{"ast":null,"code":"export default {\n  name: 'Home',\n  data() {\n    return {\n      stats: [{\n        label: '人员总数',\n        value: 0\n      }, {\n        label: '学生总数',\n        value: 0\n      }, {\n        label: '教职工总数',\n        value: 0\n      }, {\n        label: '课程总数',\n        value: 0\n      }, {\n        label: '院系总数',\n        value: 0\n      }, {\n        label: '项目总数',\n        value: 0\n      }]\n    };\n  },\n  created() {\n    this.fetchStats();\n  },\n  methods: {\n    async fetchStats() {\n      try {\n        // 获取人员总数\n        const personsResponse = await this.$axios.get('persons/');\n        this.stats[0].value = personsResponse.data.count || personsResponse.data.length || 0;\n\n        // 获取学生总数\n        const studentsResponse = await this.$axios.get('students/');\n        this.stats[1].value = studentsResponse.data.count || studentsResponse.data.length || 0;\n\n        // 获取教职工总数\n        const staffsResponse = await this.$axios.get('staffs/');\n        this.stats[2].value = staffsResponse.data.count || staffsResponse.data.length || 0;\n\n        // 获取课程总数\n        const coursesResponse = await this.$axios.get('courses/');\n        this.stats[3].value = coursesResponse.data.count || coursesResponse.data.length || 0;\n\n        // 获取院系总数\n        const departmentsResponse = await this.$axios.get('departments/');\n        this.stats[4].value = departmentsResponse.data.count || departmentsResponse.data.length || 0;\n\n        // 获取项目总数\n        const programsResponse = await this.$axios.get('programs/');\n        this.stats[5].value = programsResponse.data.count || programsResponse.data.length || 0;\n      } catch (error) {\n        console.error('获取统计数据失败:', error);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","stats","label","value","created","fetchStats","methods","personsResponse","$axios","get","count","length","studentsResponse","staffsResponse","coursesResponse","departmentsResponse","programsResponse","error","console"],"sources":["/Users/nemoyu/Desktop/database-数据库系统/小组作业/DBSM_Group_Product_copyTest/DjangoProject/frontend/src/views/Home.vue"],"sourcesContent":["<template>\n  <div class=\"home\">\n    <el-card class=\"welcome-card\">\n      <template #header>\n        <div class=\"card-header\">\n          <h2>欢迎使用教育管理系统</h2>\n        </div>\n      </template>\n      <div class=\"card-content\">\n        <p>本系统提供全面的教育管理功能，包括人员管理、课程管理、院系管理等。</p>\n        <el-row :gutter=\"20\" class=\"stat-row\">\n          <el-col :span=\"8\" v-for=\"(stat, index) in stats\" :key=\"index\">\n            <el-card class=\"stat-card\" shadow=\"hover\">\n              <h3>{{ stat.label }}</h3>\n              <div class=\"stat-value\">{{ stat.value }}</div>\n            </el-card>\n          </el-col>\n        </el-row>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'Home',\n  data() {\n    return {\n      stats: [\n        { label: '人员总数', value: 0 },\n        { label: '学生总数', value: 0 },\n        { label: '教职工总数', value: 0 },\n        { label: '课程总数', value: 0 },\n        { label: '院系总数', value: 0 },\n        { label: '项目总数', value: 0 }\n      ]\n    }\n  },\n  created() {\n    this.fetchStats()\n  },\n  methods: {\n    async fetchStats() {\n      try {\n        // 获取人员总数\n        const personsResponse = await this.$axios.get('persons/')\n        this.stats[0].value = personsResponse.data.count || personsResponse.data.length || 0\n        \n        // 获取学生总数\n        const studentsResponse = await this.$axios.get('students/')\n        this.stats[1].value = studentsResponse.data.count || studentsResponse.data.length || 0\n        \n        // 获取教职工总数\n        const staffsResponse = await this.$axios.get('staffs/')\n        this.stats[2].value = staffsResponse.data.count || staffsResponse.data.length || 0\n        \n        // 获取课程总数\n        const coursesResponse = await this.$axios.get('courses/')\n        this.stats[3].value = coursesResponse.data.count || coursesResponse.data.length || 0\n        \n        // 获取院系总数\n        const departmentsResponse = await this.$axios.get('departments/')\n        this.stats[4].value = departmentsResponse.data.count || departmentsResponse.data.length || 0\n        \n        // 获取项目总数\n        const programsResponse = await this.$axios.get('programs/')\n        this.stats[5].value = programsResponse.data.count || programsResponse.data.length || 0\n      } catch (error) {\n        console.error('获取统计数据失败:', error)\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.welcome-card {\n  margin-bottom: 20px;\n}\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.card-content {\n  text-align: center;\n}\n.stat-row {\n  margin-top: 20px;\n}\n.stat-card {\n  text-align: center;\n  margin-bottom: 20px;\n}\n.stat-value {\n  font-size: 24px;\n  font-weight: bold;\n  color: #409EFF;\n  margin-top: 10px;\n}\n</style>"],"mappings":"AAwBA,eAAe;EACbA,IAAI,EAAE,MAAM;EACZC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,CACL;QAAEC,KAAK,EAAE,MAAM;QAAEC,KAAK,EAAE;MAAE,CAAC,EAC3B;QAAED,KAAK,EAAE,MAAM;QAAEC,KAAK,EAAE;MAAE,CAAC,EAC3B;QAAED,KAAK,EAAE,OAAO;QAAEC,KAAK,EAAE;MAAE,CAAC,EAC5B;QAAED,KAAK,EAAE,MAAM;QAAEC,KAAK,EAAE;MAAE,CAAC,EAC3B;QAAED,KAAK,EAAE,MAAM;QAAEC,KAAK,EAAE;MAAE,CAAC,EAC3B;QAAED,KAAK,EAAE,MAAM;QAAEC,KAAK,EAAE;MAAE;IAE9B;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,UAAU,CAAC;EAClB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,UAAUA,CAAA,EAAG;MACjB,IAAI;QACF;QACA,MAAME,eAAc,GAAI,MAAM,IAAI,CAACC,MAAM,CAACC,GAAG,CAAC,UAAU;QACxD,IAAI,CAACR,KAAK,CAAC,CAAC,CAAC,CAACE,KAAI,GAAII,eAAe,CAACP,IAAI,CAACU,KAAI,IAAKH,eAAe,CAACP,IAAI,CAACW,MAAK,IAAK;;QAEnF;QACA,MAAMC,gBAAe,GAAI,MAAM,IAAI,CAACJ,MAAM,CAACC,GAAG,CAAC,WAAW;QAC1D,IAAI,CAACR,KAAK,CAAC,CAAC,CAAC,CAACE,KAAI,GAAIS,gBAAgB,CAACZ,IAAI,CAACU,KAAI,IAAKE,gBAAgB,CAACZ,IAAI,CAACW,MAAK,IAAK;;QAErF;QACA,MAAME,cAAa,GAAI,MAAM,IAAI,CAACL,MAAM,CAACC,GAAG,CAAC,SAAS;QACtD,IAAI,CAACR,KAAK,CAAC,CAAC,CAAC,CAACE,KAAI,GAAI