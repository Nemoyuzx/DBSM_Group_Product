{"ast":null,"code":"import { ref, reactive, onMounted, computed } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { useStore } from 'vuex';\nimport axios from 'axios';\nexport default {\n  name: 'Staffs',\n  setup() {\n    const store = useStore();\n    const router = useRouter();\n\n    // 状态变量\n    const staffs = ref([]);\n    const loading = ref(false);\n    const error = ref(null);\n    const currentPage = ref(1);\n    const pageSize = ref(10);\n    const totalItems = ref(0);\n    const searchQuery = ref('');\n    const statusFilter = ref('');\n\n    // 对话框状态\n    const dialogVisible = ref(false);\n    const deleteDialogVisible = ref(false);\n    const isEdit = ref(false);\n    const deleteItem = ref(null);\n    const staffForm = ref(null);\n\n    // 人员选择相关\n    const personOptions = ref([]);\n    const personsLoading = ref(false);\n\n    // 表单数据\n    const form = reactive({\n      staff_id: '',\n      hire_date: new Date(),\n      employment_type: 'full-time',\n      staff_status: 'active'\n    });\n\n    // 表单验证规则\n    const rules = {\n      staff_id: [{\n        required: true,\n        message: '请选择人员',\n        trigger: 'change'\n      }],\n      hire_date: [{\n        required: true,\n        message: '请选择入职日期',\n        trigger: 'change'\n      }],\n      employment_type: [{\n        required: true,\n        message: '请选择雇佣类型',\n        trigger: 'change'\n      }],\n      staff_status: [{\n        required: true,\n        message: '请选择在职状态',\n        trigger: 'change'\n      }]\n    };\n\n    // 获取教职工列表\n    const fetchStaffs = async () => {\n      loading.value = true;\n      error.value = null;\n      try {\n        let url = `staffs/?page=${currentPage.value}`;\n        if (searchQuery.value) {\n          url += `&search=${searchQuery.value}`;\n        }\n        if (statusFilter.value) {\n          url += `&staff_status=${statusFilter.value}`;\n        }\n        const response = await axios.get(url);\n        staffs.value = response.data.results || response.data;\n        totalItems.value = response.data.count || staffs.value.length;\n      } catch (err) {\n        error.value = err.message || '获取教职工数据失败';\n        console.error('Error fetching staffs:', err);\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 搜索人员\n    const searchPersons = async query => {\n      if (query.length < 2) return;\n      personsLoading.value = true;\n      try {\n        const response = await axios.get(`persons/?search=${query}`);\n        personOptions.value = response.data.results || response.data;\n      } catch (err) {\n        console.error('Error searching persons:', err);\n      } finally {\n        personsLoading.value = false;\n      }\n    };\n\n    // 显示添加对话框\n    const showAddDialog = () => {\n      isEdit.value = false;\n      Object.assign(form, {\n        staff_id: '',\n        hire_date: new Date(),\n        employment_type: 'full-time',\n        staff_status: 'active'\n      });\n      dialogVisible.value = true;\n    };\n\n    // 编辑教职工\n    const editStaff = staff => {\n      isEdit.value = true;\n      Object.assign(form, {\n        staff_id: staff.staff_id,\n        hire_date: staff.hire_date,\n        employment_type: staff.employment_type,\n        staff_status: staff.staff_status\n      });\n      dialogVisible.value = true;\n    };\n\n    // 查看教职工详情\n    const viewStaff = staff => {\n      router.push(`/persons/${staff.staff_id}`);\n    };\n\n    // 确认删除对话框\n    const confirmDelete = staff => {\n      deleteItem.value = staff;\n      deleteDialogVisible.value = true;\n    };\n\n    // 删除教职工\n    const deleteStaff = async () => {\n      try {\n        await axios.delete(`staffs/${deleteItem.value.staff_id}/`);\n        await fetchStaffs();\n        deleteDialogVisible.value = false;\n        deleteItem.value = null;\n      } catch (err) {\n        console.error('Error deleting staff:', err);\n        error.value = err.message || '删除教职工失败';\n      }\n    };\n\n    // 提交表单\n    const submitForm = async () => {\n      if (!staffForm.value) return;\n      await staffForm.value.validate(async valid => {\n        if (valid) {\n          try {\n            if (isEdit.value) {\n              // 更新教职工\n              await axios.put(`staffs/${form.staff_id}/`, form);\n            } else {\n              // 添加教职工\n              await axios.post('staffs/', form);\n            }\n            dialogVisible.value = false;\n            await fetchStaffs();\n          } catch (err) {\n            console.error('Error saving staff:', err);\n            error.value = err.message || '保存教职工数据失败';\n          }\n        }\n      });\n    };\n\n    // 处理分页\n    const handlePageChange = page => {\n      currentPage.value = page;\n      fetchStaffs();\n    };\n\n    // 获取雇佣类型显示文本\n    const getEmploymentType = type => {\n      const typeMap = {\n        'full-time': '全职',\n        'part-time': '兼职',\n        'adjunct': '临时',\n        'GTA': '助教'\n      };\n      return typeMap[type] || type;\n    };\n\n    // 获取在职状态显示文本\n    const getStaffStatus = status => {\n      const statusMap = {\n        'active': '在职',\n        'leave': '休假',\n        'retired': '退休'\n      };\n      return statusMap[status] || status;\n    };\n\n    // 初始化\n    onMounted(() => {\n      fetchStaffs();\n    });\n    return {\n      staffs,\n      loading,\n      error,\n      currentPage,\n      pageSize,\n      totalItems,\n      searchQuery,\n      statusFilter,\n      dialogVisible,\n      deleteDialogVisible,\n      isEdit,\n      deleteItem,\n      staffForm,\n      form,\n      rules,\n      personOptions,\n      personsLoading,\n      fetchStaffs,\n      searchPersons,\n      showAddDialog,\n      editStaff,\n      viewStaff,\n      confirmDelete,\n      deleteStaff,\n      submitForm,\n      handlePageChange,\n      getEmploymentType,\n      getStaffStatus\n    };\n  }\n};","map":{"version":3,"names":["ref","reactive","onMounted","computed","useRouter","useStore","axios","name","setup","store","router","staffs","loading","error","currentPage","pageSize","totalItems","searchQuery","statusFilter","dialogVisible","deleteDialogVisible","isEdit","deleteItem","staffForm","personOptions","personsLoading","form","staff_id","hire_date","Date","employment_type","staff_status","rules","required","message","trigger","fetchStaffs","value","url","response","get","data","results","count","length","err","console","searchPersons","query","showAddDialog","Object","assign","editStaff","staff","viewStaff","push","confirmDelete","deleteStaff","delete","submitForm","validate","valid","put","post","handlePageChange","page","getEmploymentType","type","typeMap","getStaffStatus","status","statusMap"],"sources":["/Users/nemoyu/Desktop/database-数据库系统/小组作业/DBSM_Group_Product_copyTest/DjangoProject/frontend/src/views/Staffs.vue"],"sourcesContent":["<template>\n  <div class=\"staffs\">\n    <el-card>\n      <template #header>\n        <div class=\"card-header\">\n          <h2>教职工管理</h2>\n          <el-button type=\"primary\" @click=\"showAddDialog\">添加教职工</el-button>\n        </div>\n      </template>\n      \n      <!-- 搜索栏 -->\n      <el-row :gutter=\"20\" class=\"search-row\">\n        <el-col :span=\"6\">\n          <el-input v-model=\"searchQuery\" placeholder=\"搜索教职工...\" clearable @clear=\"fetchStaffs\">\n            <template #append>\n              <el-button @click=\"fetchStaffs\">搜索</el-button>\n            </template>\n          </el-input>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-select v-model=\"statusFilter\" placeholder=\"在职状态\" clearable @change=\"fetchStaffs\">\n            <el-option label=\"在职\" value=\"active\" />\n            <el-option label=\"休假\" value=\"leave\" />\n            <el-option label=\"退休\" value=\"retired\" />\n          </el-select>\n        </el-col>\n      </el-row>\n      \n      <!-- 数据表格 -->\n      <el-table \n        :data=\"staffs\" \n        style=\"width: 100%\" \n        v-loading=\"loading\"\n        border\n      >\n        <el-table-column prop=\"staff_id\" label=\"工号\" width=\"100\" />\n        <el-table-column prop=\"staff_name\" label=\"姓名\" />\n        <el-table-column prop=\"hire_date\" label=\"入职日期\" width=\"120\" />\n        <el-table-column prop=\"employment_type\" label=\"雇佣类型\" width=\"100\">\n          <template #default=\"scope\">\n            {{ getEmploymentType(scope.row.employment_type) }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"staff_status\" label=\"在职状态\" width=\"100\">\n          <template #default=\"scope\">\n            {{ getStaffStatus(scope.row.staff_status) }}\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"200\">\n          <template #default=\"scope\">\n            <el-button size=\"small\" @click=\"viewStaff(scope.row)\">查看</el-button>\n            <el-button size=\"small\" type=\"primary\" @click=\"editStaff(scope.row)\">编辑</el-button>\n            <el-button size=\"small\" type=\"danger\" @click=\"confirmDelete(scope.row)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n      \n      <!-- 分页 -->\n      <div class=\"pagination-container\">\n        <el-pagination\n          v-if=\"totalItems > 0\"\n          :current-page=\"currentPage\"\n          :page-size=\"pageSize\"\n          :total=\"totalItems\"\n          layout=\"total, prev, pager, next\"\n          @current-change=\"handlePageChange\"\n        />\n      </div>\n    </el-card>\n    \n    <!-- 添加/编辑对话框 -->\n    <el-dialog \n      :title=\"isEdit ? '编辑教职工' : '添加教职工'\" \n      v-model=\"dialogVisible\"\n      width=\"50%\"\n    >\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"staffForm\" label-width=\"100px\">\n        <el-form-item label=\"人员\" prop=\"staff_id\" v-if=\"!isEdit\">\n          <el-select \n            v-model=\"form.staff_id\" \n            filterable \n            remote \n            placeholder=\"请选择人员\" \n            :remote-method=\"searchPersons\"\n            :loading=\"personsLoading\"\n          >\n            <el-option \n              v-for=\"person in personOptions\" \n              :key=\"person.person_id\" \n              :label=\"`${person.legal_name} (${person.person_id})`\" \n              :value=\"person.person_id\" \n            />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"入职日期\" prop=\"hire_date\">\n          <el-date-picker v-model=\"form.hire_date\" type=\"date\" placeholder=\"选择日期\" />\n        </el-form-item>\n        <el-form-item label=\"雇佣类型\" prop=\"employment_type\">\n          <el-select v-model=\"form.employment_type\" placeholder=\"请选择雇佣类型\">\n            <el-option label=\"全职\" value=\"full-time\" />\n            <el-option label=\"兼职\" value=\"part-time\" />\n            <el-option label=\"临时\" value=\"adjunct\" />\n            <el-option label=\"助教\" value=\"GTA\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"在职状态\" prop=\"staff_status\">\n          <el-select v-model=\"form.staff_status\" placeholder=\"请选择在职状态\">\n            <el-option label=\"在职\" value=\"active\" />\n            <el-option label=\"休假\" value=\"leave\" />\n            <el-option label=\"退休\" value=\"retired\" />\n          </el-select>\n        </el-form-item>\n      </el-form>\n      <template #footer>\n        <span class=\"dialog-footer\">\n          <el-button @click=\"dialogVisible = false\">取消</el-button>\n          <el-button type=\"primary\" @click=\"submitForm\">确定</el-button>\n        </span>\n      </template>\n    </el-dialog>\n    \n    <!-- 删除确认对话框 -->\n    <el-dialog\n      title=\"确认删除\"\n      v-model=\"deleteDialogVisible\"\n      width=\"30%\"\n    >\n      <p>确定要删除教职工 {{ deleteItem?.staff_name || '' }} 吗？此操作不可恢复。</p>\n      <template #footer>\n        <span class=\"dialog-footer\">\n          <el-button @click=\"deleteDialogVisible = false\">取消</el-button>\n          <el-button type=\"danger\" @click=\"deleteStaff\">确定删除</el-button>\n        </span>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { ref, reactive, onMounted, computed } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { useStore } from 'vuex'\nimport axios from 'axios'\n\nexport default {\n  name: 'Staffs',\n  setup() {\n    const store = useStore()\n    const router = useRouter()\n    \n    // 状态变量\n    const staffs = ref([])\n    const loading = ref(false)\n    const error = ref(null)\n    const currentPage = ref(1)\n    const pageSize = ref(10)\n    const totalItems = ref(0)\n    const searchQuery = ref('')\n    const statusFilter = ref('')\n    \n    // 对话框状态\n    const dialogVisible = ref(false)\n    const deleteDialogVisible = ref(false)\n    const isEdit = ref(false)\n    const deleteItem = ref(null)\n    const staffForm = ref(null)\n    \n    // 人员选择相关\n    const personOptions = ref([])\n    const personsLoading = ref(false)\n    \n    // 表单数据\n    const form = reactive({\n      staff_id: '',\n      hire_date: new Date(),\n      employment_type: 'full-time',\n      staff_status: 'active'\n    })\n    \n    // 表单验证规则\n    const rules = {\n      staff_id: [\n        { required: true, message: '请选择人员', trigger: 'change' }\n      ],\n      hire_date: [\n        { required: true, message: '请选择入职日期', trigger: 'change' }\n      ],\n      employment_type: [\n        { required: true, message: '请选择雇佣类型', trigger: 'change' }\n      ],\n      staff_status: [\n        { required: true, message: '请选择在职状态', trigger: 'change' }\n      ]\n    }\n    \n    // 获取教职工列表\n    const fetchStaffs = async () => {\n      loading.value = true\n      error.value = null\n      try {\n        let url = `staffs/?page=${currentPage.value}`\n        \n        if (searchQuery.value) {\n          url += `&search=${searchQuery.value}`\n        }\n        \n        if (statusFilter.value) {\n          url += `&staff_status=${statusFilter.value}`\n        }\n        \n        const response = await axios.get(url)\n        staffs.value = response.data.results || response.data\n        totalItems.value = response.data.count || staffs.value.length\n      } catch (err) {\n        error.value = err.message || '获取教职工数据失败'\n        console.error('Error fetching staffs:', err)\n      } finally {\n        loading.value = false\n      }\n    }\n    \n    // 搜索人员\n    const searchPersons = async (query) => {\n      if (query.length < 2) return\n      personsLoading.value = true\n      try {\n        const response = await axios.get(`persons/?search=${query}`)\n        personOptions.value = response.data.results || response.data\n      } catch (err) {\n        console.error('Error searching persons:', err)\n      } finally {\n        personsLoading.value = false\n      }\n    }\n    \n    // 显示添加对话框\n    const showAddDialog = () => {\n      isEdit.value = false\n      Object.assign(form, {\n        staff_id: '',\n        hire_date: new Date(),\n        employment_type: 'full-time',\n        staff_status: 'active'\n      })\n      dialogVisible.value = true\n    }\n    \n    // 编辑教职工\n    const editStaff = (staff) => {\n      isEdit.value = true\n      Object.assign(form, {\n        staff_id: staff.staff_id,\n        hire_date: staff.hire_date,\n        employment_type: staff.employment_type,\n        staff_status: staff.staff_status\n      })\n      dialogVisible.value = true\n    }\n    \n    // 查看教职工详情\n    const viewStaff = (staff) => {\n      router.push(`/persons/${staff.staff_id}`)\n    }\n    \n    // 确认删除对话框\n    const confirmDelete = (staff) => {\n      deleteItem.value = staff\n      deleteDialogVisible.value = true\n    }\n    \n    // 删除教职工\n    const deleteStaff = async () => {\n      try {\n        await axios.delete(`staffs/${deleteItem.value.staff_id}/`)\n        await fetchStaffs()\n        deleteDialogVisible.value = false\n        deleteItem.value = null\n      } catch (err) {\n        console.error('Error deleting staff:', err)\n        error.value = err.message || '删除教职工失败'\n      }\n    }\n    \n    // 提交表单\n    const submitForm = async () => {\n      if (!staffForm.value) return\n      \n      await staffForm.value.validate(async (valid) => {\n        if (valid) {\n          try {\n            if (isEdit.value) {\n              // 更新教职工\n              await axios.put(`staffs/${form.staff_id}/`, form)\n            } else {\n              // 添加教职工\n              await axios.post('staffs/', form)\n            }\n            dialogVisible.value = false\n            await fetchStaffs()\n          } catch (err) {\n            console.error('Error saving staff:', err)\n            error.value = err.message || '保存教职工数据失败'\n          }\n        }\n      })\n    }\n    \n    // 处理分页\n    const handlePageChange = (page) => {\n      currentPage.value = page\n      fetchStaffs()\n    }\n    \n    // 获取雇佣类型显示文本\n    const getEmploymentType = (type) => {\n      const typeMap = {\n        'full-time': '全职',\n        'part-time': '兼职',\n        'adjunct': '临时',\n        'GTA': '助教'\n      }\n      return typeMap[type] || type\n    }\n    \n    // 获取在职状态显示文本\n    const getStaffStatus = (status) => {\n      const statusMap = {\n        'active': '在职',\n        'leave': '休假',\n        'retired': '退休'\n      }\n      return statusMap[status] || status\n    }\n    \n    // 初始化\n    onMounted(() => {\n      fetchStaffs()\n    })\n    \n    return {\n      staffs,\n      loading,\n      error,\n      currentPage,\n      pageSize,\n      totalItems,\n      searchQuery,\n      statusFilter,\n      dialogVisible,\n      deleteDialogVisible,\n      isEdit,\n      deleteItem,\n      staffForm,\n      form,\n      rules,\n      personOptions,\n      personsLoading,\n      fetchStaffs,\n      searchPersons,\n      showAddDialog,\n      editStaff,\n      viewStaff,\n      confirmDelete,\n      deleteStaff,\n      submitForm,\n      handlePageChange,\n      getEmploymentType,\n      getStaffStatus\n    }\n  }\n}\n</script>\n\n<style scoped>\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.search-row {\n  margin-bottom: 20px;\n}\n.pagination-container {\n  margin-top: 20px;\n  display: flex;\n  justify-content: center;\n}\n</style>"],"mappings":"AA2IA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,EAAEC,QAAO,QAAS,KAAI;AACvD,SAASC,SAAQ,QAAS,YAAW;AACrC,SAASC,QAAO,QAAS,MAAK;AAC9B,OAAOC,KAAI,MAAO,OAAM;AAExB,eAAe;EACbC,IAAI,EAAE,QAAQ;EACdC,KAAKA,CAAA,EAAG;IACN,MAAMC,KAAI,GAAIJ,QAAQ,CAAC;IACvB,MAAMK,MAAK,GAAIN,SAAS,CAAC;;IAEzB;IACA,MAAMO,MAAK,GAAIX,GAAG,CAAC,EAAE;IACrB,MAAMY,OAAM,GAAIZ,GAAG,CAAC,KAAK;IACzB,MAAMa,KAAI,GAAIb,GAAG,CAAC,IAAI;IACtB,MAAMc,WAAU,GAAId,GAAG,CAAC,CAAC;IACzB,MAAMe,QAAO,GAAIf,GAAG,CAAC,EAAE;IACvB,MAAMgB,UAAS,GAAIhB,GAAG,CAAC,CAAC;IACxB,MAAMiB,WAAU,GAAIjB,GAAG,CAAC,EAAE;IAC1B,MAAMkB,YAAW,GAAIlB,GAAG,CAAC,EAAE;;IAE3B;IACA,MAAMmB,aAAY,GAAInB,GAAG,CAAC,KAAK;IAC/B,MAAMoB,mBAAkB,GAAIpB,GAAG,CAAC,KAAK;IACrC,MAAMqB,MAAK,GAAIrB,GAAG,CAAC,KAAK;IACxB,MAAMsB,UAAS,GAAItB,GAAG,CAAC,IAAI;IAC3B,MAAMuB,SAAQ,GAAIvB,GAAG,CAAC,IAAI;;IAE1B;IACA,MAAMwB,aAAY,GAAIxB,GAAG,CAAC,EAAE;IAC5B,MAAMyB,cAAa,GAAIzB,GAAG,CAAC,KAAK;;IAEhC;IACA,MAAM0B,IAAG,GAAIzB,QAAQ,CAAC;MACpB0B,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAE,IAAIC,IAAI,CAAC,CAAC;MACrBC,eAAe,EAAE,WAAW;MAC5BC,YAAY,EAAE;IAChB,CAAC;;IAED;IACA,MAAMC,KAAI,GAAI;MACZL,QAAQ,EAAE,CACR;QAAEM,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,OAAO;QAAEC,OAAO,EAAE;MAAS,EACvD;MACDP,SAAS,EAAE,CACT;QAAEK,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,SAAS;QAAEC,OAAO,EAAE;MAAS,EACzD;MACDL,eAAe,EAAE,CACf;QAAEG,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,SAAS;QAAEC,OAAO,EAAE;MAAS,EACzD;MACDJ,YAAY,EAAE,CACZ;QAAEE,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,SAAS;QAAEC,OAAO,EAAE;MAAS;IAE5D;;IAEA;IACA,MAAMC,WAAU,GAAI,MAAAA,CAAA,KAAY;MAC9BxB,OAAO,CAACyB,KAAI,GAAI,IAAG;MACnBxB,KAAK,CAACwB,KAAI,GAAI,IAAG;MACjB,IAAI;QACF,IAAIC,GAAE,GAAI,gBAAgBxB,WAAW,CAACuB,KAAK,EAAC;QAE5C,IAAIpB,WAAW,CAACoB,KAAK,EAAE;UACrBC,GAAE,IAAK,WAAWrB,WAAW,CAACoB,KAAK,EAAC;QACtC;QAEA,IAAInB,YAAY,CAACmB,KAAK,EA